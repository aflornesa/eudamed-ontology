    :hasReportDate "2024-01-15"^^xsd:date ;
    :hasOutcome "Serious patient injury - embolic stroke" ;
    :hasPatientAge "58"^^xsd:integer ;
    :hasCountryReported "Germany" ;
    :hasEudamedIncidentRef "EU-INC-2024-000001" ;
    :isReportedFor :DEV-001 ;
    :involvesRisk :RSK-003 .

# =====================================================================
# INSTANCES — Corrective Actions
# =====================================================================

