# =====================================================================
# SWRL RULES
# (Encoded as annotations; must be added in Protégé via Window > Views > Rules)
# =====================================================================

# Rule 1: If a device is implantable and active, classify it as a high-risk candidate
# Device(?d) ^ isImplantable(?d, true) ^ isActive(?d, true) ->
#   hasRiskClass(?d, ClassIII_instance)

# Rule 2: If an incident triggers a corrective action and the action is Open,
# the device is considered under active monitoring
# Incident(?i) ^ triggersCorrectiveAction(?i, ?fsca) ^ hasFscaStatus(?fsca, "Open") ^
#   isReportedFor(?i, ?d) -> underActiveMonitoring(?d, true)

# Rule 3: If a device has a risk classified as Critical severity and has an incident,
# then the incident is a SeriousIncident
# Risk(?r) ^ hasSeverity(?r, "Critical") ^ involvesRisk(?i, ?r) ->
#   SeriousIncident(?i)
