    rdfs:label "FSCA-001 HeartMate 3 Safety Alert" ;
    rdfs:comment "Safety alert issued to all implanting centres regarding anticoagulation protocol update for HeartMate 3 to reduce thrombosis risk." ;
    :hasFscaId "FSCA-001" ;
    :hasActionDate "2024-02-01"^^xsd:date ;
    :hasFscaStatus "Open" ;
    :hasDevicesAffected "850"^^xsd:integer ;
    :hasEudamedFscaRef "EU-FSCA-2024-000001" .

:INC-001 :triggersCorrectiveAction :FSCA-001 .

