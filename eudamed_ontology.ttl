# =====================================================================
# INSTANCES — Risk Classes
# =====================================================================

:ClassIIa_instance rdf:type :ClassIIa ;
    rdfs:label "Class IIa Risk Instance" ;
    rdfs:comment "Instance representing the MDR Class IIa risk classification." .

:ClassIIb_instance rdf:type :ClassIIb ;
    rdfs:label "Class IIb Risk Instance" ;
    rdfs:comment "Instance representing the MDR Class IIb risk classification." .

:ClassIII_instance rdf:type :ClassIII ;
    rdfs:label "Class III Risk Instance" ;
    rdfs:comment "Instance representing the MDR Class III risk classification." .

:ClassC_instance rdf:type :ClassC ;
    rdfs:label "IVDR Class C Risk Instance" ;
    rdfs:comment "Instance representing the IVDR Class C risk classification." .

:ClassD_instance rdf:type :ClassD ;
    rdfs:label "IVDR Class D Risk Instance" ;
    rdfs:comment "Instance representing the IVDR Class D risk classification." .

# Transitive subclassification relationships (Exercici 1, Apartat 2)
:ClassIIa_instance :isSubclassifiedUnder :ClassIIb_instance .
:ClassIIb_instance :isSubclassifiedUnder :ClassIII_instance .

# =====================================================================
# INSTANCES — Risks
# =====================================================================

:RSK-001 rdf:type :MalfunctionRisk ;
    rdfs:label "Device failure - electrical" ;
    rdfs:comment "Complete loss of electrical function leading to device shutdown in active devices." ;
    :hasRiskId "RSK-001" ;
    :hasIMDRFCode "A0101" ;
    :hasSeverity "Critical" ;
    :hasProbability "Low" .

:RSK-003 rdf:type :InjuryRisk ;
    rdfs:label "Thrombosis - device-related" ;
    rdfs:comment "Thrombus formation on device surface causing embolic events in implantable active devices." ;
    :hasRiskId "RSK-003" ;
    :hasIMDRFCode "A0201" ;
    :hasSeverity "Critical" ;
    :hasProbability "Low" .

# =====================================================================
# INSTANCES — Incidents
# =====================================================================

