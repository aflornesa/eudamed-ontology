<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.example.org/eudamed#"
     xml:base="http://www.example.org/eudamed"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:eudamed="http://www.example.org/eudamed#">
    <owl:Ontology rdf:about="http://www.example.org/eudamed">
        <terms:creator>Abel Florensa Palau</terms:creator>
        <terms:date>2026-04-12</terms:date>
        <terms:description>An ontology modelling the European catalogue of high-risk medical devices and in-vitro diagnostics under MDR (EU 2017/745) and IVDR (EU 2017/746) regulations.</terms:description>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:rights>This ontology is licensed under CC BY 4.0. You are free to share and adapt it with attribution.</terms:rights>
        <terms:title>EUDAMED Medical Devices Ontology</terms:title>
        <owl:versionInfo>1.0.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/date -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/date"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/rights -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/rights"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->


    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.example.org/eudamed#hasAssociatedIncident -->


    <owl:ObjectProperty rdf:about="http://www.example.org/eudamed#hasAssociatedIncident">
        <owl:inverseOf rdf:resource="http://www.example.org/eudamed#isReportedFor"/>
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.example.org/eudamed#Incident"/>
        <rdfs:comment>Inverse of isReportedFor. Relates a device to incidents reported for it.</rdfs:comment>
        <rdfs:label>has associated incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/eudamed#hasIdentifiedRisk -->


    <owl:ObjectProperty rdf:about="http://www.example.org/eudamed#hasIdentifiedRisk">
        <owl:inverseOf rdf:resource="http://www.example.org/eudamed#isRiskOf"/>
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.example.org/eudamed#Risk"/>
        <rdfs:comment>Relates a medical device to a risk identified for that device type.</rdfs:comment>
        <rdfs:label>has identified risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/eudamed#hasRiskClass -->


    <owl:ObjectProperty rdf:about="http://www.example.org/eudamed#hasRiskClass">
        <owl:inverseOf rdf:resource="http://www.example.org/eudamed#hasRiskClassifiedDevice"/>
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.example.org/eudamed#RegulatoryClass"/>
        <rdfs:comment>Relates a medical device to its regulatory risk classification.</rdfs:comment>
        <rdfs:label>has risk class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/eudamed#hasRiskClassifiedDevice -->


    <owl:ObjectProperty rdf:about="http://www.example.org/eudamed#hasRiskClassifiedDevice">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#RegulatoryClass"/>
        <rdfs:range rdf:resource="http://www.example.org/eudamed#MedicalDevice"/>
        <rdfs:comment>Inverse of hasRiskClass. Relates a regulatory class to the devices assigned to it.</rdfs:comment>
        <rdfs:label>has risk-classified device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/eudamed#involvesRisk -->


    <owl:ObjectProperty rdf:about="http://www.example.org/eudamed#involvesRisk">
        <owl:inverseOf rdf:resource="http://www.example.org/eudamed#isMaterialisedIn"/>
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/eudamed#Risk"/>
        <rdfs:comment>Relates an incident to the risk that materialised.</rdfs:comment>
        <rdfs:label>involves risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/eudamed#isManufacturedBy -->


    <owl:ObjectProperty rdf:about="http://www.example.org/eudamed#isManufacturedBy">
        <owl:inverseOf rdf:resource="http://www.example.org/eudamed#isManufacturerOf"/>
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.example.org/eudamed#Manufacturer"/>
        <rdfs:comment>Relates a medical device to its manufacturer.</rdfs:comment>
        <rdfs:label>is manufactured by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/eudamed#isManufacturerOf -->


    <owl:ObjectProperty rdf:about="http://www.example.org/eudamed#isManufacturerOf">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.example.org/eudamed#MedicalDevice"/>
        <rdfs:comment>Inverse of isManufacturedBy. Relates a manufacturer to the devices it produces.</rdfs:comment>
        <rdfs:label>is manufacturer of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/eudamed#isMaterialisedIn -->


    <owl:ObjectProperty rdf:about="http://www.example.org/eudamed#isMaterialisedIn">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#Risk"/>
        <rdfs:range rdf:resource="http://www.example.org/eudamed#Incident"/>
        <rdfs:comment>Inverse of involvesRisk. Relates a risk to the incidents in which it materialised.</rdfs:comment>
        <rdfs:label>is materialised in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/eudamed#isReportedFor -->


    <owl:ObjectProperty rdf:about="http://www.example.org/eudamed#isReportedFor">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/eudamed#MedicalDevice"/>
        <rdfs:comment>Relates an incident to the medical device involved in the event.</rdfs:comment>
        <rdfs:label>is reported for</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/eudamed#isRiskOf -->


    <owl:ObjectProperty rdf:about="http://www.example.org/eudamed#isRiskOf">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#Risk"/>
        <rdfs:range rdf:resource="http://www.example.org/eudamed#MedicalDevice"/>
        <rdfs:comment>Inverse of hasIdentifiedRisk. Relates a risk to the device types it is associated with.</rdfs:comment>
        <rdfs:label>is risk of</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/eudamed#isSubclassifiedUnder -->


    <owl:ObjectProperty rdf:about="http://www.example.org/eudamed#isSubclassifiedUnder">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#RegulatoryClass"/>
        <rdfs:range rdf:resource="http://www.example.org/eudamed#RegulatoryClass"/>
        <rdfs:comment>Transitive property relating a risk class to a higher risk class in the regulatory hierarchy.</rdfs:comment>
        <rdfs:label>is subclassified under</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/eudamed#isTriggeredBy -->


    <owl:ObjectProperty rdf:about="http://www.example.org/eudamed#isTriggeredBy">
        <owl:inverseOf rdf:resource="http://www.example.org/eudamed#triggersCorrectiveAction"/>
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.example.org/eudamed#Incident"/>
        <rdfs:comment>Inverse of triggersCorrectiveAction. Relates an FSCA to the incident that prompted it.</rdfs:comment>
        <rdfs:label>is triggered by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.example.org/eudamed#triggersCorrectiveAction -->


    <owl:ObjectProperty rdf:about="http://www.example.org/eudamed#triggersCorrectiveAction">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#Incident"/>
        <rdfs:range rdf:resource="http://www.example.org/eudamed#CorrectiveAction"/>
        <rdfs:comment>Relates an incident to the field safety corrective action it prompted.</rdfs:comment>
        <rdfs:label>triggers corrective action</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.example.org/eudamed#hasActionDate -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#hasActionDate">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>The date on which the corrective action was initiated.</rdfs:comment>
        <rdfs:label>has action date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#hasAuthorizationNumber -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#hasAuthorizationNumber">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The official registration/authorization number issued by the national competent authority.</rdfs:comment>
        <rdfs:label>has authorization number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#hasContactEmail -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#hasContactEmail">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The official regulatory contact email address of the manufacturer.</rdfs:comment>
        <rdfs:label>has contact email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#hasCountry -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#hasCountry">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The country where the manufacturer is registered.</rdfs:comment>
        <rdfs:label>has country</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#hasCountryReported -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#hasCountryReported">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The EU member state where the incident was reported.</rdfs:comment>
        <rdfs:label>has country reported</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#hasDeviceId -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#hasDeviceId">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The unique EUDAMED identifier for a medical device (e.g., DEV-001).</rdfs:comment>
        <rdfs:label>has device ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#hasDevicesAffected -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#hasDevicesAffected">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>The number of devices affected by the field safety corrective action.</rdfs:comment>
        <rdfs:label>has devices affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#hasEudamedFscaRef -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#hasEudamedFscaRef">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The official EUDAMED reference number for the FSCA.</rdfs:comment>
        <rdfs:label>has EUDAMED FSCA reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#hasEudamedIncidentRef -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#hasEudamedIncidentRef">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The official EUDAMED reference number for the incident.</rdfs:comment>
        <rdfs:label>has EUDAMED incident reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#hasEudamedSRN -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#hasEudamedSRN">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The Single Registration Number (SRN) assigned by EUDAMED to the manufacturer.</rdfs:comment>
        <rdfs:label>has EUDAMED SRN</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#hasFscaId -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#hasFscaId">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The internal identifier for a field safety corrective action (e.g., FSCA-001).</rdfs:comment>
        <rdfs:label>has FSCA ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#hasFscaStatus -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#hasFscaStatus">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The current status of the corrective action (Open or Closed).</rdfs:comment>
        <rdfs:label>has FSCA status</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#hasIMDRFCode -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#hasIMDRFCode">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The standardised IMDRF code used to classify the type of adverse event.</rdfs:comment>
        <rdfs:label>has IMDRF code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#hasIncidentId -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#hasIncidentId">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The internal identifier of the incident (e.g., INC-001).</rdfs:comment>
        <rdfs:label>has incident ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#hasIntendedPurpose -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#hasIntendedPurpose">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A description of the intended clinical use of the device as declared by the manufacturer.</rdfs:comment>
        <rdfs:label>has intended purpose</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#hasManufacturerId -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#hasManufacturerId">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The internal identifier for a manufacturer (e.g., MAN-001).</rdfs:comment>
        <rdfs:label>has manufacturer ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#hasOutcome -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#hasOutcome">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>A textual description of the clinical outcome of the incident.</rdfs:comment>
        <rdfs:label>has outcome</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#hasPatientAge -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#hasPatientAge">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>The age of the patient involved in the incident.</rdfs:comment>
        <rdfs:label>has patient age</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#hasProbability -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#hasProbability">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The estimated probability of the risk occurring (e.g., Low, Medium, High).</rdfs:comment>
        <rdfs:label>has probability</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#hasRegulatoryFramework -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#hasRegulatoryFramework">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The regulation under which the device is classified (MDR or IVDR).</rdfs:comment>
        <rdfs:label>has regulatory framework</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#hasReportDate -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#hasReportDate">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>The date on which the incident was formally reported to the competent authority.</rdfs:comment>
        <rdfs:label>has report date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#hasRiskId -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#hasRiskId">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The internal identifier for a risk (e.g., RSK-001).</rdfs:comment>
        <rdfs:label>has risk ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#hasSeverity -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#hasSeverity">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The severity level of the risk (e.g., Critical, Serious, Minor).</rdfs:comment>
        <rdfs:label>has severity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#hasUdiDi -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#hasUdiDi">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>The Unique Device Identifier Device Identifier (UDI-DI), a mandatory code under MDR/IVDR.</rdfs:comment>
        <rdfs:label>has UDI-DI</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#isActive -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#isActive">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Boolean flag indicating whether the device requires an energy source other than the human body.</rdfs:comment>
        <rdfs:label>is active</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#isIVD -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#isIVD">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Boolean flag indicating whether the device is an in vitro diagnostic device.</rdfs:comment>
        <rdfs:label>is IVD</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#isImplantable -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#isImplantable">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Boolean flag indicating whether the device is intended to be implanted in the human body.</rdfs:comment>
        <rdfs:label>is implantable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#isReusable -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#isReusable">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Boolean flag indicating whether the device is intended for reuse.</rdfs:comment>
        <rdfs:label>is reusable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.example.org/eudamed#isUnderMonitoring -->


    <owl:DatatypeProperty rdf:about="http://www.example.org/eudamed#isUnderMonitoring">
        <rdfs:domain rdf:resource="http://www.example.org/eudamed#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Indicates that a medical device is currently subject to active post-market surveillance due to an open FSCA. Inferred by SWRL Rule 2.</rdfs:comment>
        <rdfs:label>is under monitoring</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.example.org/eudamed#ActiveDevice -->


    <owl:Class rdf:about="http://www.example.org/eudamed#ActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#MedicalDevice"/>
        <rdfs:comment>A medical device whose operation depends on a source of energy other than that generated by the human body or gravity.</rdfs:comment>
        <rdfs:label>Active Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#ActiveImplant -->


    <owl:Class rdf:about="http://www.example.org/eudamed#ActiveImplant">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#ActiveDevice"/>
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#ImplantableDevice"/>
        <rdfs:comment>An implantable device that also requires a source of energy to operate. Combines properties of both ActiveDevice and ImplantableDevice.</rdfs:comment>
        <rdfs:label>Active Implant</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#ClassA -->


    <owl:Class rdf:about="http://www.example.org/eudamed#ClassA">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#IVDRClass"/>
        <rdfs:comment>Lowest IVDR risk class.</rdfs:comment>
        <rdfs:comment>Lowest IVDR risk class. Low individual and public health risk.</rdfs:comment>
        <rdfs:label>IVDR Class A</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#ClassB -->


    <owl:Class rdf:about="http://www.example.org/eudamed#ClassB">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#IVDRClass"/>
        <rdfs:comment>Low-medium IVDR risk class.</rdfs:comment>
        <rdfs:label>IVDR Class B</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#ClassC -->


    <owl:Class rdf:about="http://www.example.org/eudamed#ClassC">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#IVDRClass"/>
        <rdfs:comment>Medium-high IVDR risk class. Devices used for detection of serious conditions.</rdfs:comment>
        <rdfs:label>IVDR Class C</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#ClassD -->


    <owl:Class rdf:about="http://www.example.org/eudamed#ClassD">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#IVDRClass"/>
        <rdfs:comment>Highest IVDR risk class. Devices for detection of life-threatening conditions or blood screening.</rdfs:comment>
        <rdfs:label>IVDR Class D</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#ClassI -->


    <owl:Class rdf:about="http://www.example.org/eudamed#ClassI">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#MDRClass"/>
        <rdfs:comment>Lowest MDR risk class.</rdfs:comment>
        <rdfs:comment>Lowest MDR risk class. Devices pose minimal risk to patients and users.</rdfs:comment>
        <rdfs:label>Class I</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#ClassIII -->


    <owl:Class rdf:about="http://www.example.org/eudamed#ClassIII">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#MDRClass"/>
        <rdfs:comment>Highest MDR risk class. Devices that support or sustain life, implantable or cause serious risks.</rdfs:comment>
        <rdfs:label>Class III</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#ClassIIa -->


    <owl:Class rdf:about="http://www.example.org/eudamed#ClassIIa">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#MDRClass"/>
        <rdfs:comment>Medium-low MDR risk class. Devices intended for short-term use or moderate risk.</rdfs:comment>
        <rdfs:label>Class IIa</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#ClassIIb -->


    <owl:Class rdf:about="http://www.example.org/eudamed#ClassIIb">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#MDRClass"/>
        <rdfs:comment>Medium-high MDR risk class.</rdfs:comment>
        <rdfs:comment>Medium-high MDR risk class. Devices with higher potential hazard to patients.</rdfs:comment>
        <rdfs:label>Class IIb</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#CorrectiveAction -->


    <owl:Class rdf:about="http://www.example.org/eudamed#CorrectiveAction">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#MedicalEntity"/>
        <rdfs:comment>An action taken by a manufacturer to reduce risk associated with a medical device already placed on the market (FSCA).</rdfs:comment>
        <rdfs:label>Field Safety Corrective Action</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#IVDRClass -->


    <owl:Class rdf:about="http://www.example.org/eudamed#IVDRClass">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#RegulatoryClass"/>
        <owl:disjointWith rdf:resource="http://www.example.org/eudamed#MDRClass"/>
        <rdfs:comment>Risk classification under the In Vitro Diagnostic Regulation (EU 2017/746). Includes Class A, B, C, and D.</rdfs:comment>
        <rdfs:label>IVDR Risk Class</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#ImplantableActiveDevice -->


    <owl:Class rdf:about="http://www.example.org/eudamed#ImplantableActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#ActiveImplant"/>
        <rdfs:comment>A fully implantable active device with integrated energy source, such as a ventricular assist device.</rdfs:comment>
        <rdfs:label>Implantable Active Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#ImplantableDevice -->


    <owl:Class rdf:about="http://www.example.org/eudamed#ImplantableDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#MedicalDevice"/>
        <rdfs:comment>A device intended to be totally or partially introduced into the human body and to remain after the procedure.</rdfs:comment>
        <rdfs:label>Implantable Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#InSituCorrection -->


    <owl:Class rdf:about="http://www.example.org/eudamed#InSituCorrection">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#CorrectiveAction"/>
        <rdfs:comment>A FSCA where the device is corrected on-site without removal.</rdfs:comment>
        <rdfs:label>In Situ Correction</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#InVitroDiagnosticDevice -->


    <owl:Class rdf:about="http://www.example.org/eudamed#InVitroDiagnosticDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#MedicalDevice"/>
        <rdfs:comment>A device intended to examine specimens derived from the human body, as defined in IVDR EU 2017/746.</rdfs:comment>
        <rdfs:label>In Vitro Diagnostic Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#Incident -->


    <owl:Class rdf:about="http://www.example.org/eudamed#Incident">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#MedicalEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/eudamed#isReportedFor"/>
                <owl:minCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minCardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>A malfunction, deterioration, or failure of a medical device that has led to or may lead to serious injury.</rdfs:comment>
        <rdfs:label>Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#InfectionRisk -->


    <owl:Class rdf:about="http://www.example.org/eudamed#InfectionRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#Risk"/>
        <rdfs:comment>A risk related to microbial contamination or transmission of infectious agents via the device.</rdfs:comment>
        <rdfs:label>Infection Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#InjuryRisk -->


    <owl:Class rdf:about="http://www.example.org/eudamed#InjuryRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#Risk"/>
        <rdfs:comment>A risk that may directly cause injury or harm to a patient or user.</rdfs:comment>
        <rdfs:label>Injury Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#MDRClass -->


    <owl:Class rdf:about="http://www.example.org/eudamed#MDRClass">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#RegulatoryClass"/>
        <rdfs:comment>Risk classification under the Medical Device Regulation (EU 2017/745). Includes Class I, IIa, IIb, and III.</rdfs:comment>
        <rdfs:label>MDR Risk Class</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#MalfunctionRisk -->


    <owl:Class rdf:about="http://www.example.org/eudamed#MalfunctionRisk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#Risk"/>
        <rdfs:comment>A risk arising from the failure or malfunction of the device itself.</rdfs:comment>
        <rdfs:label>Malfunction Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#Manufacturer -->


    <owl:Class rdf:about="http://www.example.org/eudamed#Manufacturer">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#MedicalEntity"/>
        <rdfs:comment>A natural or legal person who manufactures or fully refurbishes a medical device and places it on the market.</rdfs:comment>
        <rdfs:label>Manufacturer</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#MedicalDevice -->


    <owl:Class rdf:about="http://www.example.org/eudamed#MedicalDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#MedicalEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/eudamed#isManufacturedBy"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.example.org/eudamed#hasUdiDi"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Any instrument, apparatus, appliance or software intended by the manufacturer for human beings, as defined in MDR EU 2017/745.</rdfs:comment>
        <rdfs:label>Medical Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#MedicalEntity -->


    <owl:Class rdf:about="http://www.example.org/eudamed#MedicalEntity">
        <rdfs:comment>Top-level class for all entities modelled in the EUDAMED ontology.</rdfs:comment>
        <rdfs:label>Medical Entity</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#NonSeriousIncident -->


    <owl:Class rdf:about="http://www.example.org/eudamed#NonSeriousIncident">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#Incident"/>
        <owl:disjointWith rdf:resource="http://www.example.org/eudamed#SeriousIncident"/>
        <rdfs:comment>An incident that did not result in serious injury but was reported to the competent authority.</rdfs:comment>
        <rdfs:label>Non-Serious Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#Recall -->


    <owl:Class rdf:about="http://www.example.org/eudamed#Recall">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#CorrectiveAction"/>
        <rdfs:comment>A FSCA involving the return or replacement of the affected device.</rdfs:comment>
        <rdfs:label>Recall</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#RegulatoryClass -->


    <owl:Class rdf:about="http://www.example.org/eudamed#RegulatoryClass">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#MedicalEntity"/>
        <rdfs:comment>A risk classification assigned to a medical device under European regulations MDR or IVDR.</rdfs:comment>
        <rdfs:label>Regulatory Class</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#Risk -->


    <owl:Class rdf:about="http://www.example.org/eudamed#Risk">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#MedicalEntity"/>
        <rdfs:comment>A potential harm associated with a medical device, classified according to the IMDRF nomenclature.</rdfs:comment>
        <rdfs:label>Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#SafetyAlert -->


    <owl:Class rdf:about="http://www.example.org/eudamed#SafetyAlert">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#CorrectiveAction"/>
        <rdfs:comment>A FSCA consisting of a safety communication issued to healthcare professionals.</rdfs:comment>
        <rdfs:label>Safety Alert</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#SelfTestDevice -->


    <owl:Class rdf:about="http://www.example.org/eudamed#SelfTestDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#InVitroDiagnosticDevice"/>
        <rdfs:comment>An IVD device intended to be used by lay persons in a home environment.</rdfs:comment>
        <rdfs:label>Self-Test Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#SeriousIncident -->


    <owl:Class rdf:about="http://www.example.org/eudamed#SeriousIncident">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#Incident"/>
        <rdfs:comment>An incident that directly or indirectly led to or could lead to the death of a patient or user.</rdfs:comment>
        <rdfs:label>Serious Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.example.org/eudamed#SingleUseDevice -->


    <owl:Class rdf:about="http://www.example.org/eudamed#SingleUseDevice">
        <rdfs:subClassOf rdf:resource="http://www.example.org/eudamed#MedicalDevice"/>
        <rdfs:comment>A device intended to be used on one individual during a single procedure and not reused.</rdfs:comment>
        <rdfs:label>Single Use Device</rdfs:label>
    </owl:Class>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.example.org/eudamed#ClassC_instance -->


    <owl:NamedIndividual rdf:about="http://www.example.org/eudamed#ClassC_instance">
        <rdf:type rdf:resource="http://www.example.org/eudamed#ClassC"/>
        <rdfs:comment>Instance representing the IVDR Class C risk classification.</rdfs:comment>
        <rdfs:label>IVDR Class C Risk Instance</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/eudamed#ClassD_instance -->


    <owl:NamedIndividual rdf:about="http://www.example.org/eudamed#ClassD_instance">
        <rdf:type rdf:resource="http://www.example.org/eudamed#ClassD"/>
        <rdfs:comment>Instance representing the IVDR Class D risk classification.</rdfs:comment>
        <rdfs:label>IVDR Class D Risk Instance</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/eudamed#ClassIII_instance -->


    <owl:NamedIndividual rdf:about="http://www.example.org/eudamed#ClassIII_instance">
        <rdf:type rdf:resource="http://www.example.org/eudamed#ClassIII"/>
        <rdfs:comment>Instance representing the MDR Class III risk classification.</rdfs:comment>
        <rdfs:label>Class III Risk Instance</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/eudamed#ClassIIa_instance -->


    <owl:NamedIndividual rdf:about="http://www.example.org/eudamed#ClassIIa_instance">
        <rdf:type rdf:resource="http://www.example.org/eudamed#ClassIIa"/>
        <isSubclassifiedUnder rdf:resource="http://www.example.org/eudamed#ClassIIb_instance"/>
        <rdfs:comment>Instance representing the MDR Class IIa risk classification.</rdfs:comment>
        <rdfs:label>Class IIa Risk Instance</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/eudamed#ClassIIb_instance -->


    <owl:NamedIndividual rdf:about="http://www.example.org/eudamed#ClassIIb_instance">
        <rdf:type rdf:resource="http://www.example.org/eudamed#ClassIIb"/>
        <isSubclassifiedUnder rdf:resource="http://www.example.org/eudamed#ClassIII_instance"/>
        <rdfs:comment>Instance representing the MDR Class IIb risk classification.</rdfs:comment>
        <rdfs:label>Class IIb Risk Instance</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/eudamed#DEV-001 -->


    <owl:NamedIndividual rdf:about="http://www.example.org/eudamed#DEV-001">
        <rdf:type rdf:resource="http://www.example.org/eudamed#ImplantableActiveDevice"/>
        <hasRiskClass rdf:resource="http://www.example.org/eudamed#ClassIII_instance"/>
        <isManufacturedBy rdf:resource="http://www.example.org/eudamed#MAN-001"/>
        <hasDeviceId>DEV-001</hasDeviceId>
        <hasIntendedPurpose>Ventricular assist device for end-stage heart failure</hasIntendedPurpose>
        <hasRegulatoryFramework>MDR</hasRegulatoryFramework>
        <hasUdiDi>(01)00380740009095</hasUdiDi>
        <isActive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isActive>
        <isIVD rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isIVD>
        <isImplantable rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isImplantable>
        <isReusable rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isReusable>
        <rdfs:comment>Left ventricular assist device for patients with end-stage heart failure, implanted in the chest.</rdfs:comment>
        <rdfs:label>HeartMate 3 LVAD</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/eudamed#DEV-007 -->


    <owl:NamedIndividual rdf:about="http://www.example.org/eudamed#DEV-007">
        <rdf:type rdf:resource="http://www.example.org/eudamed#ActiveDevice"/>
        <hasRiskClass rdf:resource="http://www.example.org/eudamed#ClassIIa_instance"/>
        <isManufacturedBy rdf:resource="http://www.example.org/eudamed#MAN-003"/>
        <hasDeviceId>DEV-007</hasDeviceId>
        <hasIntendedPurpose>Diagnostic ultrasound imaging system</hasIntendedPurpose>
        <hasRegulatoryFramework>MDR</hasRegulatoryFramework>
        <hasUdiDi>(01)04054839450001</hasUdiDi>
        <isActive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isActive>
        <isIVD rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isIVD>
        <isImplantable rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isImplantable>
        <isReusable rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isReusable>
        <rdfs:comment>Premium diagnostic ultrasound imaging system for cardiology, radiology and obstetrics.</rdfs:comment>
        <rdfs:label>ACUSON Sequoia Ultrasound</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/eudamed#DEV-016 -->


    <owl:NamedIndividual rdf:about="http://www.example.org/eudamed#DEV-016">
        <rdf:type rdf:resource="http://www.example.org/eudamed#InVitroDiagnosticDevice"/>
        <hasRiskClass rdf:resource="http://www.example.org/eudamed#ClassC_instance"/>
        <isManufacturedBy rdf:resource="http://www.example.org/eudamed#MAN-005"/>
        <hasDeviceId>DEV-016</hasDeviceId>
        <hasIntendedPurpose>Automated immunoassay analyzer for clinical laboratory</hasIntendedPurpose>
        <hasRegulatoryFramework>IVDR</hasRegulatoryFramework>
        <hasUdiDi>(01)04015630001016</hasUdiDi>
        <isActive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isActive>
        <isIVD rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isIVD>
        <isImplantable rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isImplantable>
        <isReusable rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isReusable>
        <rdfs:comment>High-throughput automated immunoassay analyzer for clinical laboratory use, classified IVDR Class C.</rdfs:comment>
        <rdfs:label>cobas e 801 Immunoassay Analyzer</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/eudamed#DEV-018 -->


    <owl:NamedIndividual rdf:about="http://www.example.org/eudamed#DEV-018">
        <rdf:type rdf:resource="http://www.example.org/eudamed#InVitroDiagnosticDevice"/>
        <hasRiskClass rdf:resource="http://www.example.org/eudamed#ClassD_instance"/>
        <isManufacturedBy rdf:resource="http://www.example.org/eudamed#MAN-015_bioMerieux"/>
        <hasDeviceId>DEV-018</hasDeviceId>
        <hasIntendedPurpose>Combined HIV Ag/Ab detection assay</hasIntendedPurpose>
        <hasRegulatoryFramework>IVDR</hasRegulatoryFramework>
        <hasUdiDi>(01)03760027001018</hasUdiDi>
        <isActive rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isActive>
        <isIVD rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</isIVD>
        <isImplantable rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isImplantable>
        <isReusable rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">false</isReusable>
        <rdfs:comment>Combined HIV antigen and antibody detection assay for blood screening, IVDR Class D.</rdfs:comment>
        <rdfs:label>VIDAS HIV DUO Ultra</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/eudamed#FSCA-001 -->


    <owl:NamedIndividual rdf:about="http://www.example.org/eudamed#FSCA-001">
        <rdf:type rdf:resource="http://www.example.org/eudamed#SafetyAlert"/>
        <hasActionDate rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2024-02-01</hasActionDate>
        <hasDevicesAffected rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">850</hasDevicesAffected>
        <hasEudamedFscaRef>EU-FSCA-2024-000001</hasEudamedFscaRef>
        <hasFscaId>FSCA-001</hasFscaId>
        <hasFscaStatus>Open</hasFscaStatus>
        <rdfs:comment>Safety alert issued to all implanting centres regarding anticoagulation protocol update for HeartMate 3 to reduce thrombosis risk.</rdfs:comment>
        <rdfs:label>FSCA-001 HeartMate 3 Safety Alert</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- http://www.example.org/eudamed#INC-001 -->


    <owl:NamedIndividual rdf:about="http://www.example.org/eudamed#INC-001">
        <rdf:type rdf:resource="http://www.example.org/eudamed#SeriousIncident"/>
        <involvesRisk rdf:resource="http://www.example.org/eudamed#RSK-003"/>
