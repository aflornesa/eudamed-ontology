    "@value" : "Boolean flag indicating whether the device is intended to be implanted in the human body."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.example.org/eudamed#MedicalDevice"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "is implantable"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.w3.org/2001/XMLSchema#boolean"
  } ]
}, {
  "@id" : "http://www.example.org/eudamed#isManufacturedBy",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
