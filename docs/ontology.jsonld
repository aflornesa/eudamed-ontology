    "@value" : "1.0.0"
  } ]
}, {
  "@id" : "http://www.example.org/eudamed#ActiveDevice",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "A medical device whose operation depends on a source of energy other than that generated by the human body or gravity."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Active Device"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.example.org/eudamed#MedicalDevice"
  } ]
}, {
  "@id" : "http://www.example.org/eudamed#ActiveImplant",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "An implantable device that also requires a source of energy to operate. Combines properties of both ActiveDevice and ImplantableDevice."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Active Implant"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.example.org/eudamed#ActiveDevice"
  }, {
    "@id" : "http://www.example.org/eudamed#ImplantableDevice"
  } ]
}, {
  "@id" : "http://www.example.org/eudamed#ClassA",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Lowest IVDR risk class."
  }, {
    "@value" : "Lowest IVDR risk class. Low individual and public health risk."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "IVDR Class A"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.example.org/eudamed#IVDRClass"
  } ]
}, {
  "@id" : "http://www.example.org/eudamed#ClassB",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Low-medium IVDR risk class."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "IVDR Class B"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.example.org/eudamed#IVDRClass"
  } ]
}, {
  "@id" : "http://www.example.org/eudamed#ClassC",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Medium-high IVDR risk class. Devices used for detection of serious conditions."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "IVDR Class C"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.example.org/eudamed#IVDRClass"
  } ]
}, {
  "@id" : "http://www.example.org/eudamed#ClassC_instance",
  "@type" : [ "http://www.w3.org/2002/07/owl#NamedIndividual" ],
  "http://www.w3.org/1999/02/22-rdf-syntax-ns#type" : [ {
    "@id" : "http://www.example.org/eudamed#ClassC"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Instance representing the IVDR Class C risk classification."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "IVDR Class C Risk Instance"
  } ]
}, {
  "@id" : "http://www.example.org/eudamed#ClassD",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Highest IVDR risk class. Devices for detection of life-threatening conditions or blood screening."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "IVDR Class D"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.example.org/eudamed#IVDRClass"
  } ]
}, {
