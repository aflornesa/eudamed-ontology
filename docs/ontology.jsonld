  } ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Instance representing the IVDR Class D risk classification."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "IVDR Class D Risk Instance"
  } ]
}, {
  "@id" : "http://www.example.org/eudamed#ClassI",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Lowest MDR risk class."
  }, {
    "@value" : "Lowest MDR risk class. Devices pose minimal risk to patients and users."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Class I"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.example.org/eudamed#MDRClass"
  } ]
}, {
  "@id" : "http://www.example.org/eudamed#ClassIII",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
