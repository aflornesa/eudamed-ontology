    "@value" : "Relates a medical device to its manufacturer."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.example.org/eudamed#MedicalDevice"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "is manufactured by"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.example.org/eudamed#Manufacturer"
  } ],
  "http://www.w3.org/2002/07/owl#inverseOf" : [ {
    "@id" : "http://www.example.org/eudamed#isManufacturerOf"
  } ]
}, {
  "@id" : "http://www.example.org/eudamed#isManufacturerOf",
  "@type" : [ "http://www.w3.org/2002/07/owl#ObjectProperty" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Inverse of isManufacturedBy. Relates a manufacturer to the devices it produces."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#domain" : [ {
    "@id" : "http://www.example.org/eudamed#Manufacturer"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "is manufacturer of"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#range" : [ {
    "@id" : "http://www.example.org/eudamed#MedicalDevice"
  } ]
}, {
