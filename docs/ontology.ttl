         :hasRiskClass :ClassIIa_instance ;
         :isManufacturedBy :MAN-003 ;
         :hasDeviceId "DEV-007" ;
         :hasIntendedPurpose "Diagnostic ultrasound imaging system" ;
         :hasRegulatoryFramework "MDR" ;
         :hasUdiDi "(01)04054839450001" ;
         :isActive "true"^^xsd:boolean ;
         :isIVD "false"^^xsd:boolean ;
         :isImplantable "false"^^xsd:boolean ;
         :isReusable "true"^^xsd:boolean ;
         rdfs:comment "Premium diagnostic ultrasound imaging system for cardiology, radiology and obstetrics." ;
         rdfs:label "ACUSON Sequoia Ultrasound" .


###  http://www.example.org/eudamed#DEV-016
:DEV-016 rdf:type owl:NamedIndividual ,
