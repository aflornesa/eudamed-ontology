@prefix : <http://www.example.org/eudamed#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.example.org/eudamed#> .

<http://www.example.org/eudamed> rdf:type owl:Ontology ;
                                  <http://purl.org/dc/terms/creator> "Abel Florensa Palau" ;
                                  <http://purl.org/dc/terms/date> "2026-04-12" ;
                                  <http://purl.org/dc/terms/description> "An ontology modelling the European catalogue of high-risk medical devices and in-vitro diagnostics under MDR (EU 2017/745) and IVDR (EU 2017/746) regulations." ;
                                  <http://purl.org/dc/terms/license> <https://creativecommons.org/licenses/by/4.0/> ;
                                  <http://purl.org/dc/terms/rights> "This ontology is licensed under CC BY 4.0. You are free to share and adapt it with attribution." ;
                                  <http://purl.org/dc/terms/title> "EUDAMED Medical Devices Ontology" ;
                                  owl:versionInfo "1.0.0" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/date
<http://purl.org/dc/terms/date> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/rights
<http://purl.org/dc/terms/rights> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/title
<http://purl.org/dc/terms/title> rdf:type owl:AnnotationProperty .


###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .


#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  http://www.example.org/eudamed#hasAssociatedIncident
:hasAssociatedIncident rdf:type owl:ObjectProperty ;
                       owl:inverseOf :isReportedFor ;
                       rdfs:domain :MedicalDevice ;
                       rdfs:range :Incident ;
                       rdfs:comment "Inverse of isReportedFor. Relates a device to incidents reported for it." ;
                       rdfs:label "has associated incident" .


###  http://www.example.org/eudamed#hasIdentifiedRisk
:hasIdentifiedRisk rdf:type owl:ObjectProperty ;
                   owl:inverseOf :isRiskOf ;
                   rdfs:domain :MedicalDevice ;
                   rdfs:range :Risk ;
                   rdfs:comment "Relates a medical device to a risk identified for that device type." ;
                   rdfs:label "has identified risk" .


###  http://www.example.org/eudamed#hasRiskClass
:hasRiskClass rdf:type owl:ObjectProperty ;
              owl:inverseOf :hasRiskClassifiedDevice ;
              rdfs:domain :MedicalDevice ;
              rdfs:range :RegulatoryClass ;
              rdfs:comment "Relates a medical device to its regulatory risk classification." ;
              rdfs:label "has risk class" .


###  http://www.example.org/eudamed#hasRiskClassifiedDevice
:hasRiskClassifiedDevice rdf:type owl:ObjectProperty ;
                         rdfs:domain :RegulatoryClass ;
                         rdfs:range :MedicalDevice ;
                         rdfs:comment "Inverse of hasRiskClass. Relates a regulatory class to the devices assigned to it." ;
                         rdfs:label "has risk-classified device" .


###  http://www.example.org/eudamed#involvesRisk
:involvesRisk rdf:type owl:ObjectProperty ;
              owl:inverseOf :isMaterialisedIn ;
              rdfs:domain :Incident ;
              rdfs:range :Risk ;
              rdfs:comment "Relates an incident to the risk that materialised." ;
              rdfs:label "involves risk" .


###  http://www.example.org/eudamed#isManufacturedBy
:isManufacturedBy rdf:type owl:ObjectProperty ;
                  owl:inverseOf :isManufacturerOf ;
                  rdfs:domain :MedicalDevice ;
                  rdfs:range :Manufacturer ;
                  rdfs:comment "Relates a medical device to its manufacturer." ;
                  rdfs:label "is manufactured by" .


###  http://www.example.org/eudamed#isManufacturerOf
:isManufacturerOf rdf:type owl:ObjectProperty ;
                  rdfs:domain :Manufacturer ;
                  rdfs:range :MedicalDevice ;
                  rdfs:comment "Inverse of isManufacturedBy. Relates a manufacturer to the devices it produces." ;
                  rdfs:label "is manufacturer of" .


###  http://www.example.org/eudamed#isMaterialisedIn
:isMaterialisedIn rdf:type owl:ObjectProperty ;
                  rdfs:domain :Risk ;
                  rdfs:range :Incident ;
                  rdfs:comment "Inverse of involvesRisk. Relates a risk to the incidents in which it materialised." ;
                  rdfs:label "is materialised in" .


###  http://www.example.org/eudamed#isReportedFor
:isReportedFor rdf:type owl:ObjectProperty ;
               rdfs:domain :Incident ;
               rdfs:range :MedicalDevice ;
               rdfs:comment "Relates an incident to the medical device involved in the event." ;
               rdfs:label "is reported for" .


###  http://www.example.org/eudamed#isRiskOf
:isRiskOf rdf:type owl:ObjectProperty ;
          rdfs:domain :Risk ;
          rdfs:range :MedicalDevice ;
          rdfs:comment "Inverse of hasIdentifiedRisk. Relates a risk to the device types it is associated with." ;
          rdfs:label "is risk of" .


###  http://www.example.org/eudamed#isSubclassifiedUnder
:isSubclassifiedUnder rdf:type owl:ObjectProperty ,
                               owl:TransitiveProperty ;
                      rdfs:domain :RegulatoryClass ;
                      rdfs:range :RegulatoryClass ;
                      rdfs:comment "Transitive property relating a risk class to a higher risk class in the regulatory hierarchy." ;
                      rdfs:label "is subclassified under" .


###  http://www.example.org/eudamed#isTriggeredBy
:isTriggeredBy rdf:type owl:ObjectProperty ;
               owl:inverseOf :triggersCorrectiveAction ;
               rdfs:domain :CorrectiveAction ;
               rdfs:range :Incident ;
               rdfs:comment "Inverse of triggersCorrectiveAction. Relates an FSCA to the incident that prompted it." ;
               rdfs:label "is triggered by" .


###  http://www.example.org/eudamed#triggersCorrectiveAction
:triggersCorrectiveAction rdf:type owl:ObjectProperty ;
                          rdfs:domain :Incident ;
                          rdfs:range :CorrectiveAction ;
                          rdfs:comment "Relates an incident to the field safety corrective action it prompted." ;
                          rdfs:label "triggers corrective action" .


#################################################################
#    Data properties
#################################################################

###  http://www.example.org/eudamed#hasActionDate
:hasActionDate rdf:type owl:DatatypeProperty ;
               rdfs:domain :CorrectiveAction ;
               rdfs:range xsd:date ;
               rdfs:comment "The date on which the corrective action was initiated." ;
               rdfs:label "has action date" .


###  http://www.example.org/eudamed#hasAuthorizationNumber
:hasAuthorizationNumber rdf:type owl:DatatypeProperty ;
                        rdfs:domain :Manufacturer ;
                        rdfs:range xsd:string ;
                        rdfs:comment "The official registration/authorization number issued by the national competent authority." ;
                        rdfs:label "has authorization number" .


###  http://www.example.org/eudamed#hasContactEmail
:hasContactEmail rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Manufacturer ;
                 rdfs:range xsd:string ;
                 rdfs:comment "The official regulatory contact email address of the manufacturer." ;
                 rdfs:label "has contact email" .


###  http://www.example.org/eudamed#hasCountry
:hasCountry rdf:type owl:DatatypeProperty ;
            rdfs:domain :Manufacturer ;
            rdfs:range xsd:string ;
            rdfs:comment "The country where the manufacturer is registered." ;
            rdfs:label "has country" .


###  http://www.example.org/eudamed#hasCountryReported
:hasCountryReported rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Incident ;
                    rdfs:range xsd:string ;
                    rdfs:comment "The EU member state where the incident was reported." ;
                    rdfs:label "has country reported" .


###  http://www.example.org/eudamed#hasDeviceId
:hasDeviceId rdf:type owl:DatatypeProperty ;
             rdfs:domain :MedicalDevice ;
             rdfs:range xsd:string ;
             rdfs:comment "The unique EUDAMED identifier for a medical device (e.g., DEV-001)." ;
             rdfs:label "has device ID" .


###  http://www.example.org/eudamed#hasDevicesAffected
:hasDevicesAffected rdf:type owl:DatatypeProperty ;
                    rdfs:domain :CorrectiveAction ;
                    rdfs:range xsd:integer ;
                    rdfs:comment "The number of devices affected by the field safety corrective action." ;
                    rdfs:label "has devices affected" .


###  http://www.example.org/eudamed#hasEudamedFscaRef
:hasEudamedFscaRef rdf:type owl:DatatypeProperty ;
                   rdfs:domain :CorrectiveAction ;
                   rdfs:range xsd:string ;
                   rdfs:comment "The official EUDAMED reference number for the FSCA." ;
                   rdfs:label "has EUDAMED FSCA reference" .


###  http://www.example.org/eudamed#hasEudamedIncidentRef
:hasEudamedIncidentRef rdf:type owl:DatatypeProperty ;
                       rdfs:domain :Incident ;
                       rdfs:range xsd:string ;
                       rdfs:comment "The official EUDAMED reference number for the incident." ;
                       rdfs:label "has EUDAMED incident reference" .


###  http://www.example.org/eudamed#hasEudamedSRN
:hasEudamedSRN rdf:type owl:DatatypeProperty ;
               rdfs:domain :Manufacturer ;
               rdfs:range xsd:string ;
               rdfs:comment "The Single Registration Number (SRN) assigned by EUDAMED to the manufacturer." ;
               rdfs:label "has EUDAMED SRN" .


###  http://www.example.org/eudamed#hasFscaId
:hasFscaId rdf:type owl:DatatypeProperty ;
           rdfs:domain :CorrectiveAction ;
           rdfs:range xsd:string ;
           rdfs:comment "The internal identifier for a field safety corrective action (e.g., FSCA-001)." ;
           rdfs:label "has FSCA ID" .


###  http://www.example.org/eudamed#hasFscaStatus
:hasFscaStatus rdf:type owl:DatatypeProperty ;
               rdfs:domain :CorrectiveAction ;
               rdfs:range xsd:string ;
               rdfs:comment "The current status of the corrective action (Open or Closed)." ;
               rdfs:label "has FSCA status" .


###  http://www.example.org/eudamed#hasIMDRFCode
:hasIMDRFCode rdf:type owl:DatatypeProperty ;
              rdfs:domain :Risk ;
              rdfs:range xsd:string ;
              rdfs:comment "The standardised IMDRF code used to classify the type of adverse event." ;
              rdfs:label "has IMDRF code" .


###  http://www.example.org/eudamed#hasIncidentId
:hasIncidentId rdf:type owl:DatatypeProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:string ;
               rdfs:comment "The internal identifier of the incident (e.g., INC-001)." ;
               rdfs:label "has incident ID" .


###  http://www.example.org/eudamed#hasIntendedPurpose
:hasIntendedPurpose rdf:type owl:DatatypeProperty ;
                    rdfs:domain :MedicalDevice ;
                    rdfs:range xsd:string ;
                    rdfs:comment "A description of the intended clinical use of the device as declared by the manufacturer." ;
                    rdfs:label "has intended purpose" .


###  http://www.example.org/eudamed#hasManufacturerId
:hasManufacturerId rdf:type owl:DatatypeProperty ;
                   rdfs:domain :Manufacturer ;
                   rdfs:range xsd:string ;
                   rdfs:comment "The internal identifier for a manufacturer (e.g., MAN-001)." ;
                   rdfs:label "has manufacturer ID" .


###  http://www.example.org/eudamed#hasOutcome
:hasOutcome rdf:type owl:DatatypeProperty ;
            rdfs:domain :Incident ;
            rdfs:range xsd:string ;
            rdfs:comment "A textual description of the clinical outcome of the incident." ;
            rdfs:label "has outcome" .


###  http://www.example.org/eudamed#hasPatientAge
:hasPatientAge rdf:type owl:DatatypeProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:integer ;
               rdfs:comment "The age of the patient involved in the incident." ;
               rdfs:label "has patient age" .


###  http://www.example.org/eudamed#hasProbability
:hasProbability rdf:type owl:DatatypeProperty ;
                rdfs:domain :Risk ;
                rdfs:range xsd:string ;
                rdfs:comment "The estimated probability of the risk occurring (e.g., Low, Medium, High)." ;
                rdfs:label "has probability" .


###  http://www.example.org/eudamed#hasRegulatoryFramework
:hasRegulatoryFramework rdf:type owl:DatatypeProperty ;
                        rdfs:domain :MedicalDevice ;
                        rdfs:range xsd:string ;
                        rdfs:comment "The regulation under which the device is classified (MDR or IVDR)." ;
                        rdfs:label "has regulatory framework" .


###  http://www.example.org/eudamed#hasReportDate
:hasReportDate rdf:type owl:DatatypeProperty ;
               rdfs:domain :Incident ;
               rdfs:range xsd:date ;
               rdfs:comment "The date on which the incident was formally reported to the competent authority." ;
               rdfs:label "has report date" .


###  http://www.example.org/eudamed#hasRiskId
:hasRiskId rdf:type owl:DatatypeProperty ;
           rdfs:domain :Risk ;
           rdfs:range xsd:string ;
           rdfs:comment "The internal identifier for a risk (e.g., RSK-001)." ;
           rdfs:label "has risk ID" .


###  http://www.example.org/eudamed#hasSeverity
:hasSeverity rdf:type owl:DatatypeProperty ;
             rdfs:domain :Risk ;
             rdfs:range xsd:string ;
             rdfs:comment "The severity level of the risk (e.g., Critical, Serious, Minor)." ;
             rdfs:label "has severity" .


###  http://www.example.org/eudamed#hasUdiDi
:hasUdiDi rdf:type owl:DatatypeProperty ;
          rdfs:domain :MedicalDevice ;
          rdfs:range xsd:string ;
          rdfs:comment "The Unique Device Identifier Device Identifier (UDI-DI), a mandatory code under MDR/IVDR." ;
          rdfs:label "has UDI-DI" .


###  http://www.example.org/eudamed#isActive
:isActive rdf:type owl:DatatypeProperty ;
          rdfs:domain :MedicalDevice ;
          rdfs:range xsd:boolean ;
          rdfs:comment "Boolean flag indicating whether the device requires an energy source other than the human body." ;
          rdfs:label "is active" .


###  http://www.example.org/eudamed#isIVD
:isIVD rdf:type owl:DatatypeProperty ;
       rdfs:domain :MedicalDevice ;
       rdfs:range xsd:boolean ;
       rdfs:comment "Boolean flag indicating whether the device is an in vitro diagnostic device." ;
       rdfs:label "is IVD" .


###  http://www.example.org/eudamed#isImplantable
:isImplantable rdf:type owl:DatatypeProperty ;
               rdfs:domain :MedicalDevice ;
               rdfs:range xsd:boolean ;
               rdfs:comment "Boolean flag indicating whether the device is intended to be implanted in the human body." ;
               rdfs:label "is implantable" .


###  http://www.example.org/eudamed#isReusable
:isReusable rdf:type owl:DatatypeProperty ;
            rdfs:domain :MedicalDevice ;
            rdfs:range xsd:boolean ;
            rdfs:comment "Boolean flag indicating whether the device is intended for reuse." ;
            rdfs:label "is reusable" .


###  http://www.example.org/eudamed#isUnderMonitoring
:isUnderMonitoring rdf:type owl:DatatypeProperty ;
                   rdfs:domain :MedicalDevice ;
                   rdfs:range xsd:boolean ;
                   rdfs:comment "Indicates that a medical device is currently subject to active post-market surveillance due to an open FSCA. Inferred by SWRL Rule 2." ;
                   rdfs:label "is under monitoring" .


#################################################################
#    Classes
#################################################################

###  http://www.example.org/eudamed#ActiveDevice
:ActiveDevice rdf:type owl:Class ;
              rdfs:subClassOf :MedicalDevice ;
              rdfs:comment "A medical device whose operation depends on a source of energy other than that generated by the human body or gravity." ;
              rdfs:label "Active Device" .


###  http://www.example.org/eudamed#ActiveImplant
:ActiveImplant rdf:type owl:Class ;
               rdfs:subClassOf :ActiveDevice ,
                               :ImplantableDevice ;
               rdfs:comment "An implantable device that also requires a source of energy to operate. Combines properties of both ActiveDevice and ImplantableDevice." ;
               rdfs:label "Active Implant" .


###  http://www.example.org/eudamed#ClassA
:ClassA rdf:type owl:Class ;
        rdfs:subClassOf :IVDRClass ;
        rdfs:comment "Lowest IVDR risk class." ,
                     "Lowest IVDR risk class. Low individual and public health risk." ;
        rdfs:label "IVDR Class A" .


###  http://www.example.org/eudamed#ClassB
:ClassB rdf:type owl:Class ;
        rdfs:subClassOf :IVDRClass ;
        rdfs:comment "Low-medium IVDR risk class." ;
        rdfs:label "IVDR Class B" .


###  http://www.example.org/eudamed#ClassC
:ClassC rdf:type owl:Class ;
        rdfs:subClassOf :IVDRClass ;
        rdfs:comment "Medium-high IVDR risk class. Devices used for detection of serious conditions." ;
        rdfs:label "IVDR Class C" .


###  http://www.example.org/eudamed#ClassD
:ClassD rdf:type owl:Class ;
        rdfs:subClassOf :IVDRClass ;
        rdfs:comment "Highest IVDR risk class. Devices for detection of life-threatening conditions or blood screening." ;
        rdfs:label "IVDR Class D" .


###  http://www.example.org/eudamed#ClassI
:ClassI rdf:type owl:Class ;
        rdfs:subClassOf :MDRClass ;
        rdfs:comment "Lowest MDR risk class." ,
                     "Lowest MDR risk class. Devices pose minimal risk to patients and users." ;
        rdfs:label "Class I" .


###  http://www.example.org/eudamed#ClassIII
:ClassIII rdf:type owl:Class ;
          rdfs:subClassOf :MDRClass ;
          rdfs:comment "Highest MDR risk class. Devices that support or sustain life, implantable or cause serious risks." ;
          rdfs:label "Class III" .


###  http://www.example.org/eudamed#ClassIIa
:ClassIIa rdf:type owl:Class ;
          rdfs:subClassOf :MDRClass ;
          rdfs:comment "Medium-low MDR risk class. Devices intended for short-term use or moderate risk." ;
          rdfs:label "Class IIa" .


###  http://www.example.org/eudamed#ClassIIb
:ClassIIb rdf:type owl:Class ;
          rdfs:subClassOf :MDRClass ;
          rdfs:comment "Medium-high MDR risk class." ,
                       "Medium-high MDR risk class. Devices with higher potential hazard to patients." ;
          rdfs:label "Class IIb" .


###  http://www.example.org/eudamed#CorrectiveAction
:CorrectiveAction rdf:type owl:Class ;
                  rdfs:subClassOf :MedicalEntity ;
                  rdfs:comment "An action taken by a manufacturer to reduce risk associated with a medical device already placed on the market (FSCA)." ;
                  rdfs:label "Field Safety Corrective Action" .


###  http://www.example.org/eudamed#IVDRClass
:IVDRClass rdf:type owl:Class ;
           rdfs:subClassOf :RegulatoryClass ;
           owl:disjointWith :MDRClass ;
           rdfs:comment "Risk classification under the In Vitro Diagnostic Regulation (EU 2017/746). Includes Class A, B, C, and D." ;
           rdfs:label "IVDR Risk Class" .


###  http://www.example.org/eudamed#ImplantableActiveDevice
:ImplantableActiveDevice rdf:type owl:Class ;
                         rdfs:subClassOf :ActiveImplant ;
                         rdfs:comment "A fully implantable active device with integrated energy source, such as a ventricular assist device." ;
                         rdfs:label "Implantable Active Device" .


###  http://www.example.org/eudamed#ImplantableDevice
:ImplantableDevice rdf:type owl:Class ;
                   rdfs:subClassOf :MedicalDevice ;
                   rdfs:comment "A device intended to be totally or partially introduced into the human body and to remain after the procedure." ;
                   rdfs:label "Implantable Device" .


###  http://www.example.org/eudamed#InSituCorrection
:InSituCorrection rdf:type owl:Class ;
                  rdfs:subClassOf :CorrectiveAction ;
                  rdfs:comment "A FSCA where the device is corrected on-site without removal." ;
                  rdfs:label "In Situ Correction" .


###  http://www.example.org/eudamed#InVitroDiagnosticDevice
:InVitroDiagnosticDevice rdf:type owl:Class ;
                         rdfs:subClassOf :MedicalDevice ;
                         rdfs:comment "A device intended to examine specimens derived from the human body, as defined in IVDR EU 2017/746." ;
                         rdfs:label "In Vitro Diagnostic Device" .


###  http://www.example.org/eudamed#Incident
:Incident rdf:type owl:Class ;
          rdfs:subClassOf :MedicalEntity ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :isReportedFor ;
                            owl:minCardinality "1"^^xsd:nonNegativeInteger
                          ] ;
          rdfs:comment "A malfunction, deterioration, or failure of a medical device that has led to or may lead to serious injury." ;
          rdfs:label "Incident" .


###  http://www.example.org/eudamed#InfectionRisk
:InfectionRisk rdf:type owl:Class ;
               rdfs:subClassOf :Risk ;
               rdfs:comment "A risk related to microbial contamination or transmission of infectious agents via the device." ;
               rdfs:label "Infection Risk" .


###  http://www.example.org/eudamed#InjuryRisk
:InjuryRisk rdf:type owl:Class ;
            rdfs:subClassOf :Risk ;
            rdfs:comment "A risk that may directly cause injury or harm to a patient or user." ;
            rdfs:label "Injury Risk" .


###  http://www.example.org/eudamed#MDRClass
:MDRClass rdf:type owl:Class ;
          rdfs:subClassOf :RegulatoryClass ;
          rdfs:comment "Risk classification under the Medical Device Regulation (EU 2017/745). Includes Class I, IIa, IIb, and III." ;
          rdfs:label "MDR Risk Class" .


###  http://www.example.org/eudamed#MalfunctionRisk
:MalfunctionRisk rdf:type owl:Class ;
                 rdfs:subClassOf :Risk ;
                 rdfs:comment "A risk arising from the failure or malfunction of the device itself." ;
                 rdfs:label "Malfunction Risk" .


###  http://www.example.org/eudamed#Manufacturer
:Manufacturer rdf:type owl:Class ;
              rdfs:subClassOf :MedicalEntity ;
              rdfs:comment "A natural or legal person who manufactures or fully refurbishes a medical device and places it on the market." ;
              rdfs:label "Manufacturer" .


###  http://www.example.org/eudamed#MedicalDevice
:MedicalDevice rdf:type owl:Class ;
               rdfs:subClassOf :MedicalEntity ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :isManufacturedBy ;
                                 owl:cardinality "1"^^xsd:nonNegativeInteger
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasUdiDi ;
                                 owl:cardinality "1"^^xsd:nonNegativeInteger
                               ] ;
               rdfs:comment "Any instrument, apparatus, appliance or software intended by the manufacturer for human beings, as defined in MDR EU 2017/745." ;
               rdfs:label "Medical Device" .


###  http://www.example.org/eudamed#MedicalEntity
:MedicalEntity rdf:type owl:Class ;
               rdfs:comment "Top-level class for all entities modelled in the EUDAMED ontology." ;
               rdfs:label "Medical Entity" .


###  http://www.example.org/eudamed#NonSeriousIncident
:NonSeriousIncident rdf:type owl:Class ;
                    rdfs:subClassOf :Incident ;
                    owl:disjointWith :SeriousIncident ;
                    rdfs:comment "An incident that did not result in serious injury but was reported to the competent authority." ;
                    rdfs:label "Non-Serious Incident" .


###  http://www.example.org/eudamed#Recall
:Recall rdf:type owl:Class ;
        rdfs:subClassOf :CorrectiveAction ;
        rdfs:comment "A FSCA involving the return or replacement of the affected device." ;
        rdfs:label "Recall" .


###  http://www.example.org/eudamed#RegulatoryClass
:RegulatoryClass rdf:type owl:Class ;
                 rdfs:subClassOf :MedicalEntity ;
                 rdfs:comment "A risk classification assigned to a medical device under European regulations MDR or IVDR." ;
                 rdfs:label "Regulatory Class" .


###  http://www.example.org/eudamed#Risk
:Risk rdf:type owl:Class ;
      rdfs:subClassOf :MedicalEntity ;
      rdfs:comment "A potential harm associated with a medical device, classified according to the IMDRF nomenclature." ;
      rdfs:label "Risk" .


###  http://www.example.org/eudamed#SafetyAlert
:SafetyAlert rdf:type owl:Class ;
             rdfs:subClassOf :CorrectiveAction ;
             rdfs:comment "A FSCA consisting of a safety communication issued to healthcare professionals." ;
             rdfs:label "Safety Alert" .


###  http://www.example.org/eudamed#SelfTestDevice
:SelfTestDevice rdf:type owl:Class ;
                rdfs:subClassOf :InVitroDiagnosticDevice ;
                rdfs:comment "An IVD device intended to be used by lay persons in a home environment." ;
                rdfs:label "Self-Test Device" .


###  http://www.example.org/eudamed#SeriousIncident
:SeriousIncident rdf:type owl:Class ;
                 rdfs:subClassOf :Incident ;
                 rdfs:comment "An incident that directly or indirectly led to or could lead to the death of a patient or user." ;
                 rdfs:label "Serious Incident" .


###  http://www.example.org/eudamed#SingleUseDevice
:SingleUseDevice rdf:type owl:Class ;
                 rdfs:subClassOf :MedicalDevice ;
                 rdfs:comment "A device intended to be used on one individual during a single procedure and not reused." ;
                 rdfs:label "Single Use Device" .


#################################################################
#    Individuals
#################################################################

###  http://www.example.org/eudamed#ClassC_instance
:ClassC_instance rdf:type owl:NamedIndividual ,
                          :ClassC ;
                 rdfs:comment "Instance representing the IVDR Class C risk classification." ;
                 rdfs:label "IVDR Class C Risk Instance" .


###  http://www.example.org/eudamed#ClassD_instance
:ClassD_instance rdf:type owl:NamedIndividual ,
                          :ClassD ;
                 rdfs:comment "Instance representing the IVDR Class D risk classification." ;
                 rdfs:label "IVDR Class D Risk Instance" .


###  http://www.example.org/eudamed#ClassIII_instance
:ClassIII_instance rdf:type owl:NamedIndividual ,
                            :ClassIII ;
                   rdfs:comment "Instance representing the MDR Class III risk classification." ;
                   rdfs:label "Class III Risk Instance" .


###  http://www.example.org/eudamed#ClassIIa_instance
:ClassIIa_instance rdf:type owl:NamedIndividual ,
                            :ClassIIa ;
                   :isSubclassifiedUnder :ClassIIb_instance ;
                   rdfs:comment "Instance representing the MDR Class IIa risk classification." ;
                   rdfs:label "Class IIa Risk Instance" .


###  http://www.example.org/eudamed#ClassIIb_instance
:ClassIIb_instance rdf:type owl:NamedIndividual ,
                            :ClassIIb ;
                   :isSubclassifiedUnder :ClassIII_instance ;
                   rdfs:comment "Instance representing the MDR Class IIb risk classification." ;
                   rdfs:label "Class IIb Risk Instance" .


###  http://www.example.org/eudamed#DEV-001
:DEV-001 rdf:type owl:NamedIndividual ,
                  :ImplantableActiveDevice ;
         :hasRiskClass :ClassIII_instance ;
         :isManufacturedBy :MAN-001 ;
         :hasDeviceId "DEV-001" ;
         :hasIntendedPurpose "Ventricular assist device for end-stage heart failure" ;
         :hasRegulatoryFramework "MDR" ;
         :hasUdiDi "(01)00380740009095" ;
         :isActive "true"^^xsd:boolean ;
         :isIVD "false"^^xsd:boolean ;
         :isImplantable "true"^^xsd:boolean ;
         :isReusable "false"^^xsd:boolean ;
         rdfs:comment "Left ventricular assist device for patients with end-stage heart failure, implanted in the chest." ;
         rdfs:label "HeartMate 3 LVAD" .


