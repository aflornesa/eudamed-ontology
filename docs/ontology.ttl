                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#propertyPredicate> :triggersCorrectiveAction ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> :i ;
                                                                  <http://www.w3.org/2003/11/swrl#argument2> :fsca
                                                                ] ;
                                                      rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                 rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom> ;
                                                                             <http://www.w3.org/2003/11/swrl#propertyPredicate> :hasFscaStatus ;
                                                                             <http://www.w3.org/2003/11/swrl#argument1> :fsca ;
                                                                             <http://www.w3.org/2003/11/swrl#argument2> "Open"
                                                                           ] ;
                                                                 rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                            rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                                                        <http://www.w3.org/2003/11/swrl#propertyPredicate> :isReportedFor ;
                                                                                        <http://www.w3.org/2003/11/swrl#argument1> :i ;
