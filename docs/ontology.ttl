#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :ActiveDevice
                :ImplantableDevice
                :InVitroDiagnosticDevice
                :SingleUseDevice
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :ClassA
                :ClassB
                :ClassC
                :ClassD
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :ClassI
                :ClassIII
                :ClassIIa
                :ClassIIb
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :InSituCorrection
                :Recall
                :SafetyAlert
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :InfectionRisk
                :InjuryRisk
                :MalfunctionRisk
              )
] .


#################################################################
#    Rules
#################################################################

:d rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:i rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:fsca rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

:r rdf:type <http://www.w3.org/2003/11/swrl#Variable> .

[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean ;
   rdfs:comment "" ;
   rdfs:label "Classificació de risc augmentat" ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#classPredicate> :MedicalDevice ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> :d
                                                     ] ;
                                           rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                      rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom> ;
                                                                  <http://www.w3.org/2003/11/swrl#propertyPredicate> :isImplantable ;
                                                                  <http://www.w3.org/2003/11/swrl#argument1> :d ;
                                                                  <http://www.w3.org/2003/11/swrl#argument2> "true"^^xsd:boolean
                                                                ] ;
                                                      rdf:rest [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                                                 rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#DatavaluedPropertyAtom> ;
                                                                             <http://www.w3.org/2003/11/swrl#propertyPredicate> :isActive ;
                                                                             <http://www.w3.org/2003/11/swrl#argument1> :d ;
                                                                             <http://www.w3.org/2003/11/swrl#argument2> "true"^^xsd:boolean
                                                                           ] ;
                                                                 rdf:rest rdf:nil
                                                               ]
                                                    ]
                                         ] ;
   <http://www.w3.org/2003/11/swrl#head> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#IndividualPropertyAtom> ;
                                                       <http://www.w3.org/2003/11/swrl#propertyPredicate> :hasRiskClass ;
                                                       <http://www.w3.org/2003/11/swrl#argument1> :d ;
                                                       <http://www.w3.org/2003/11/swrl#argument2> :ClassIII_instance
                                                     ] ;
                                           rdf:rest rdf:nil
                                         ]
 ] .

[ <http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> "true"^^xsd:boolean ;
   rdfs:comment "" ;
   rdfs:label "Monitoratge actiu" ;
   rdf:type <http://www.w3.org/2003/11/swrl#Imp> ;
   <http://www.w3.org/2003/11/swrl#body> [ rdf:type <http://www.w3.org/2003/11/swrl#AtomList> ;
                                           rdf:first [ rdf:type <http://www.w3.org/2003/11/swrl#ClassAtom> ;
