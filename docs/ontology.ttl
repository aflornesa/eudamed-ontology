         :hasRiskClass :ClassC_instance ;
         :isManufacturedBy :MAN-005 ;
         :hasDeviceId "DEV-016" ;
         :hasIntendedPurpose "Automated immunoassay analyzer for clinical laboratory" ;
         :hasRegulatoryFramework "IVDR" ;
         :hasUdiDi "(01)04015630001016" ;
         :isActive "true"^^xsd:boolean ;
         :isIVD "true"^^xsd:boolean ;
         :isImplantable "false"^^xsd:boolean ;
         :isReusable "true"^^xsd:boolean ;
         rdfs:comment "High-throughput automated immunoassay analyzer for clinical laboratory use, classified IVDR Class C." ;
         rdfs:label "cobas e 801 Immunoassay Analyzer" .


###  http://www.example.org/eudamed#DEV-018
:DEV-018 rdf:type owl:NamedIndividual ,
                  :InVitroDiagnosticDevice ;
         :hasRiskClass :ClassD_instance ;
         :isManufacturedBy :MAN-015_bioMerieux ;
         :hasDeviceId "DEV-018" ;
         :hasIntendedPurpose "Combined HIV Ag/Ab detection assay" ;
         :hasRegulatoryFramework "IVDR" ;
         :hasUdiDi "(01)03760027001018" ;
         :isActive "false"^^xsd:boolean ;
         :isIVD "true"^^xsd:boolean ;
         :isImplantable "false"^^xsd:boolean ;
         :isReusable "false"^^xsd:boolean ;
         rdfs:comment "Combined HIV antigen and antibody detection assay for blood screening, IVDR Class D." ;
         rdfs:label "VIDAS HIV DUO Ultra" .


###  http://www.example.org/eudamed#FSCA-001
:FSCA-001 rdf:type owl:NamedIndividual ,
                   :SafetyAlert ;
          :hasActionDate "2024-02-01"^^xsd:date ;
          :hasDevicesAffected 850 ;
          :hasEudamedFscaRef "EU-FSCA-2024-000001" ;
          :hasFscaId "FSCA-001" ;
          :hasFscaStatus "Open" ;
          rdfs:comment "Safety alert issued to all implanting centres regarding anticoagulation protocol update for HeartMate 3 to reduce thrombosis risk." ;
          rdfs:label "FSCA-001 HeartMate 3 Safety Alert" .


###  http://www.example.org/eudamed#INC-001
:INC-001 rdf:type owl:NamedIndividual ,
                  :SeriousIncident ;
         :involvesRisk :RSK-003 ;
         :isReportedFor :DEV-001 ;
         :triggersCorrectiveAction :FSCA-001 ;
         :hasCountryReported "Germany" ;
         :hasEudamedIncidentRef "EU-INC-2024-000001" ;
         :hasIncidentId "INC-001" ;
         :hasOutcome "Serious patient injury - embolic stroke" ;
         :hasPatientAge 58 ;
         :hasReportDate "2024-01-15"^^xsd:date ;
         rdfs:comment "Patient implanted with HeartMate 3 LVAD developed ischemic stroke 6 months post-implant due to device thrombus." ;
         rdfs:label "INC-001 HeartMate 3 Thrombosis" .


